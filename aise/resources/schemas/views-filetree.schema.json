{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "views-filetree.schema.json",
  "title": "CodeWiki View: Filetree",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "version", "roots", "mappings"],
  "properties": {
    "kind": { "const": "view.filetree" },
    "version": { "type": "string", "minLength": 1 },
    "roots": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "mappings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "match", "targets"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "match": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "value"],
            "properties": {
              "kind": { "type": "string", "enum": ["glob", "regex", "prefix"] },
              "value": { "type": "string", "minLength": 1 }
            }
          },
          "summary": { "type": "string" },
          "targets": {
            "type": "object",
            "additionalProperties": false,
            "required": ["modules"],
            "properties": {
              "modules": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "pattern": "^[a-z0-9][a-z0-9-]*(/[a-z0-9][a-z0-9-]*)*$"
                }
              },
              "apis": { "type": "array", "items": { "type": "string" } },
              "flows": { "type": "array", "items": { "type": "string" } }
            }
          },
          "priority": { "type": "integer", "minimum": 0 },
          "source": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "ref"],
            "properties": {
              "kind": { "type": "string", "enum": ["file", "symbol", "doc", "other"] },
              "ref": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  }
}
