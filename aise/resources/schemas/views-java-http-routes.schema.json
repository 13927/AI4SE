{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "views-java-http-routes.schema.json",
  "title": "CodeWiki views/java_http_routes",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "version", "routes"],
  "properties": {
    "kind": { "const": "view.java_http_routes" },
    "version": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string" },
    "routes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["api_id", "method", "path", "handler_file", "handler_class", "chain"],
        "properties": {
          "api_id": { "type": "string", "minLength": 1 },
          "method": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "handler_file": { "type": "string", "minLength": 1 },
          "handler_class": { "type": "string", "minLength": 1 },
          "chain": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["role", "class", "module", "file"],
              "properties": {
                "role": { "type": "string", "enum": ["controller", "service", "repository", "other"] },
                "class": { "type": "string", "minLength": 1 },
                "package": { "type": "string" },
                "stereotype": { "type": "string" },
                "module": {
                  "type": "string",
                  "pattern": "^[a-z0-9][a-z0-9_-]*(/[a-z0-9][a-z0-9_-]*)*$"
                },
                "file": { "type": "string", "minLength": 1 },
                "evidence": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["kind", "ref"],
                    "properties": {
                      "kind": { "type": "string", "enum": ["file", "symbol", "doc", "other", "command"] },
                      "ref": { "type": "string", "minLength": 1 },
                      "note": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
