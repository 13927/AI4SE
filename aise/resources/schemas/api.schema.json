{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "api.schema.json",
  "title": "CodeWiki L1 API",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "id", "name", "summary", "protocol", "provenance"],
  "properties": {
    "kind": { "const": "api" },
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9][a-z0-9-]*(/[a-z0-9][a-z0-9-]*)*$"
    },
    "name": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "protocol": { "type": "string", "enum": ["http", "cli", "cpp-header", "other"] },
    "http": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "method": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "handler": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "file": { "type": "string" },
            "symbol": { "type": "string" }
          }
        }
      }
    },
    "cpp_header": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "include_path": { "type": "string", "minLength": 1 },
        "file": { "type": "string", "minLength": 1 }
      }
    },
    "related_modules": { "type": "array", "items": { "type": "string" } },
    "provenance": { "$ref": "common.schema.json#/$defs/sourcesBlock" }
  }
}

